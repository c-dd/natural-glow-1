# ===========================================================================
# Natural Glow — backend environment (TEMPLATE, safe to commit).
#
# Copy to `.env` for local `netlify dev`, and set the real values in the
# Netlify UI / CLI for deploys:
#     netlify env:set AUTH_JWT_SECRET <value> --secret
#     netlify env:set ADMIN_EMAILS "you@example.com,client@example.com"
#
# NEVER commit real secret values — only this redacted template is tracked.
# (.gitignore ignores .env* except this file.)
# ===========================================================================

# ---------------------------------------------------------------------------
# AUTH_JWT_SECRET (REQUIRED, SECRET)
# Symmetric HS256 signing key for the ng_session JWT (netlify/lib/auth.mts).
# Generate a fresh 32-byte random value:
#     node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# ---------------------------------------------------------------------------
AUTH_JWT_SECRET=__REDACTED_32_BYTE_RANDOM__

# ---------------------------------------------------------------------------
# ADMIN_EMAILS (REQUIRED)
# Comma-separated, case-insensitive allowlist. Any signed-in user whose email
# is on this list is treated as an admin (requireAdmin in netlify/lib/auth.mts),
# regardless of their stored role. This bootstraps admin access with no data
# migration. Start with the site owner; add the client later.
# ---------------------------------------------------------------------------
ADMIN_EMAILS=support@caredigitalcareers.com

# ---------------------------------------------------------------------------
# Blobs credentials — NOT needed locally (netlify dev provides a sandbox) and
# NOT needed in deployed Functions (Netlify injects the context automatically).
# Only the standalone scripts/seed.mjs tool needs these, and only when run
# OUTSIDE `netlify dev`:
#     NETLIFY_AUTH_TOKEN  (a personal access token)
#     NETLIFY_SITE_ID     (a7699410-50b6-447e-9aa6-491dff371df6)
# ---------------------------------------------------------------------------
# NETLIFY_AUTH_TOKEN=__REDACTED__
# NETLIFY_SITE_ID=a7699410-50b6-447e-9aa6-491dff371df6
